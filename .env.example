ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
# Optional. Enables the OpenAI fallback provider (gpt-5.4) used when Anthropic
# or xAI return transient errors. Unset = no fallback; primary failures propagate.
OPENAI_API_KEY=sk-proj-...

# Optional. Enables the GitHub App "Push to GitHub" feature for the agentic Coder.
# Register the App at github.com/settings/apps/new and paste credentials below.
# See: _agent-instructions/twai-swarm/github-app-setup.md
# Unset = feature disabled (endpoints return 503).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALL_URL=https://github.com/apps/cintelis-swarm/installations/new

# Optional. Enables Langfuse LLM trace capture. All three must be set for
# tracing to activate; any one missing / set to "UNSET" disables the feature.
# In AWS: these are populated by Terraform from SM; locally, copy from the
# Langfuse UI after signing up + creating a project.
# See: _agent-instructions/twai-swarm/langfuse-setup.md
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional bearer token for the API. Unset = auth disabled (dev default).
# Any random string works; UI prompts the user once and stores in localStorage.
# In prod, plumb via Secrets Manager.
# API_AUTH_TOKEN=

# Defaults below work with the supplied docker-compose.yml
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS=false
PG_DSN=postgresql://postgres:postgres@localhost:5432/agentdb

# Only set these when pointing local dev at Temporal Cloud (rare):
# TEMPORAL_HOST=ap-southeast-2.aws.api.temporal.io:7233
# TEMPORAL_NAMESPACE=quickstart-twai-swarm.m8cb4
# TEMPORAL_TLS=true
# TEMPORAL_API_KEY=tmprl_...
