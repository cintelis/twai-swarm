# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

aws_region   = "ap-southeast-2"
project_name = "lean-agent"

# Set to "owner/repo" -- must match your actual GitHub repo
github_repo = "cintelis/twai-swarm"

# Temporal Cloud (API key auth).
#   - temporal_host: the REGIONAL endpoint shown on the API-key page,
#     e.g. ap-southeast-2.aws.api.temporal.io:7233 (NOT the namespace endpoint)
#   - temporal_namespace: namespace.account_id, e.g. quickstart-twai-swarm.m8cb4
temporal_host      = "ap-southeast-2.aws.api.temporal.io:7233"
temporal_namespace = "quickstart-twai-swarm.m8cb4"

# Paste secrets directly:
anthropic_api_key = "sk-ant-..."
xai_api_key       = "xai-..."
temporal_api_key  = "tmprl_..."

db_password = "generate-a-strong-password-here"

# Leave empty to use default VPC; set for production
vpc_id = ""
