# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

aws_region   = "ap-southeast-2"
project_name = "lean-agent"

# Set to "owner/repo" -- must match your actual GitHub repo
github_repo = "cintelis/twai-swarm"

# Temporal Cloud (API key auth).
#   - temporal_host: the REGIONAL endpoint shown on the API-key page,
#     e.g. ap-southeast-2.aws.api.temporal.io:7233 (NOT the namespace endpoint)
#   - temporal_namespace: namespace.account_id, e.g. quickstart-twai-swarm.m8cb4
temporal_host      = "ap-southeast-2.aws.api.temporal.io:7233"
temporal_namespace = "quickstart-twai-swarm.m8cb4"

# Paste secrets directly:
anthropic_api_key = "sk-ant-..."
xai_api_key       = "xai-..."
# Optional: OpenAI gpt-5.4 fallback provider. Leave as "" to disable fallback.
openai_api_key    = "sk-proj-..."
temporal_api_key  = "tmprl_..."

db_password = "generate-a-strong-password-here"

# Leave empty to use default VPC; set for production (see prod-runbook.md)
vpc_id = ""

# ── HA / scaling knobs ─────────────────────────────────────────────
# Defaults below match dev. Flip for prod when ready.
#
# db_instance_class        = "db.r6g.large"       # ~$200/mo, fits real load
# db_allocated_storage     = 100                  # GB
# db_multi_az              = true                 # roughly 2x DB cost
# db_backup_retention_days = 7                    # max 35
# db_deletion_protection   = true                 # also keeps a final snapshot
#
# api_min_tasks            = 2                    # always >=2 in prod for HA
# api_max_tasks            = 20
# api_cpu_target           = 60
# api_cpu                  = 1024
# api_memory               = 2048
#
# worker_cpu               = 2048
# worker_memory            = 4096
# worker_desired_count     = 2                    # for HA; or split per-queue
