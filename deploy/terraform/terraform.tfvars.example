# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

aws_region   = "ap-southeast-2"
project_name = "lean-agent"

# Set to "owner/repo" -- must match your actual GitHub repo
github_repo = "cintelis/twai-swarm"

# Temporal Cloud -- after signing up, the endpoint has this shape:
temporal_host      = "your-namespace.abcde.tmprl.cloud:7233"
temporal_namespace = "your-namespace.abcde"

# Paste secrets directly or read from files:
anthropic_api_key        = "sk-ant-..."
xai_api_key              = "xai-..."
temporal_client_cert_pem = file("./temporal.crt")
temporal_client_key_pem  = file("./temporal.key")

db_password = "generate-a-strong-password-here"

# Leave empty to use default VPC; set for production
vpc_id = ""
